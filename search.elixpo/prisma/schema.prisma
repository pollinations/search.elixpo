generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String    @id @default(cuid())
  clientId  String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
  bookmarks Bookmark[]

  @@index([clientId])
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String   @db.Text
  sources   Json?
  images    Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Bookmark {
  id        String   @id @default(cuid())
  sessionId String
  clientId  String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model DiscoverArticle {
  id          String   @id @default(cuid())
  category    String
  title       String
  excerpt     String   @db.Text
  sourceUrl   String?
  sourceTitle String?
  imageUrl    String?
  generatedAt DateTime @default(now())
  dayKey      String

  @@index([category, dayKey])
  @@index([dayKey])
}
